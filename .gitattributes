# Normalize line endings to LF in the repo; checkout as-is on all platforms
* text=auto eol=lf

# Shell scripts must always be LF (Linux servers need this)
*.sh text eol=lf
Makefile text eol=lf

# Windows-specific files (if any) keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
