# ─────────────────────────────────────────────────────────────────────────────
# Multilingual Sentiment Dashboard — Environment Variables
# Copy this file to .env and fill in every value before starting.
#   cp .env.example .env
#
# Generate a strong SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────
APP_NAME=MultilingualSentimentDashboard
# Set to "production" in prod — disables debug output and hot-reload
ENVIRONMENT=development
DEBUG=true

# ─── Security ────────────────────────────────────────────────
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-strong-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database (PostgreSQL) ───────────────────────────────────
POSTGRES_USER=sentimentuser
POSTGRES_PASSWORD=sentimentpass
POSTGRES_DB=sentimentdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# These two must match POSTGRES_* values above
DATABASE_URL=postgresql+asyncpg://sentimentuser:sentimentpass@postgres:5432/sentimentdb
DATABASE_URL_SYNC=postgresql://sentimentuser:sentimentpass@postgres:5432/sentimentdb

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── ChromaDB (Vector Store) ─────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ─── AI / NLP ────────────────────────────────────────────────
# REQUIRED: Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Latest Claude model — change only if you want to use a different version
CLAUDE_MODEL=claude-opus-4-6
# Sentence embedding model (downloads automatically on first start)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Translation ─────────────────────────────────────────────
# Options: deep_translator (free, no key needed) | google (requires API key)
TRANSLATION_PROVIDER=deep_translator

# ─── CORS ────────────────────────────────────────────────────
# Dev: include localhost ports. Prod: set to your actual domain.
# Example (prod): ALLOWED_ORIGINS=https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── File Upload ─────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/app/uploads

# ─── Alert Thresholds ────────────────────────────────────────
# Fraction drop in sentiment score that triggers a sentiment_drop alert (0.0–1.0)
SENTIMENT_DROP_THRESHOLD=0.2
# How often the alert checker runs, in seconds (300 = every 5 minutes)
ALERT_CHECK_INTERVAL_SECONDS=300

# ─── Email / SMTP Alerts (leave empty to disable) ────────────
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Use an "App Password" (not your main password) for Gmail/Outlook
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@sentimentai.io
SMTP_TLS=true
# Comma-separated admin email(s) to receive alert notifications
ALERT_EMAIL_RECIPIENTS=

# ─── Slack Alerts (leave empty to disable) ───────────────────
# Create an Incoming Webhook app at https://api.slack.com/apps
SLACK_WEBHOOK_URL=

# ─── First Admin User ────────────────────────────────────────
# Auto-created on first startup if this email doesn't exist yet.
# Change the password immediately after first login!
FIRST_ADMIN_EMAIL=admin@sentiment.ai
FIRST_ADMIN_PASSWORD=Admin@123456
FIRST_ADMIN_NAME=Super Admin
